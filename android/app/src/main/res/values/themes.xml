<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DreamArchive" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_void</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/bg_void</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.DreamArchive">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
